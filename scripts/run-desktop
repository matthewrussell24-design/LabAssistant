#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON="$ROOT_DIR/.venv/bin/python"

if [[ ! -x "$PYTHON" ]]; then
  echo "Missing project Python at .venv/bin/python. Run: python3.12 -m venv .venv && source .venv/bin/activate && pip install -r requirements.txt" >&2
  exit 1
fi

PYSIDE_VERSION="$($PYTHON -c 'import PySide6; print(PySide6.__version__)' 2>/dev/null || true)"
if [[ "$PYSIDE_VERSION" != "6.8.3" ]]; then
  echo "LabAssistant Desktop requires PySide6 6.8.3 (found: ${PYSIDE_VERSION:-not installed}). Run: .venv/bin/pip install -r requirements.txt" >&2
  exit 1
fi

exec "$PYTHON" -m labassistant.desktop "$@"
