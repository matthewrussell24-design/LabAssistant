#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
UV="${UV:-$(command -v uv || true)}"

if [[ -z "$UV" ]]; then
  echo "uv is required to regenerate dependency locks: https://docs.astral.sh/uv/" >&2
  exit 1
fi

mkdir -p "$ROOT_DIR/requirements/locks"
for group in desktop streamlit build dev; do
  "$UV" pip compile \
    "$ROOT_DIR/requirements/$group.in" \
    --output-file "$ROOT_DIR/requirements/locks/$group-py312-macos-arm64.txt" \
    --python-version 3.12 \
    --python-platform aarch64-apple-darwin \
    --only-binary :all: \
    --generate-hashes \
    --custom-compile-command scripts/lock-dependencies
done
